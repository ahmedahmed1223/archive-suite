# Version control
.git
.gitignore
.gitattributes
.codex-scan
repo-git-backups

# Node modules (rebuilt in Docker)
node_modules
**/node_modules

# Build outputs (rebuilt in Docker)
**/dist
**/dist-cloud
**/build
**/.vite

# Test results
**/test-results
**/playwright-report
**/blob-report
**/coverage

# Development files
**/*.md
**/*.log
.env
.env.*
!.env.example
**/.env.local

# Editor & OS
.vscode
.idea
*.suo
*.swp
**/.DS_Store
**/Thumbs.db

# Test & CI
**/__tests__
**/*.test.*
**/*.spec.*
.github

# Monorepo tools
.changeset

# Docker files themselves (don't include in build context)
**/Dockerfile*
**/.dockerignore

# Reports and docs
output
docs/*
!docs/api/
docs/api/*
!docs/api/archive-contract.openapi.json

# Python (OCR service has its own Docker build)
infra/ocr-service/
**/__pycache__
**/*.pyc

# Prisma: keep schema and migrations, exclude generated client
archive-server/src/generated/

# PocketBase runtime data
archive-server/pocketbase/pb_data

# Large binary/media assets that don't belong in the server image
**/*.mp4
**/*.avi
**/*.mov
**/*.mkv
**/*.zip
**/*.tar.gz

# pgAdmin local config
infra/deploy/pgadmin-servers.json
