# Local scans and repository backups.
.codex-scan/
repo-git-backups/

# Dependencies and package-manager noise.
node_modules/
support-bundles/
**/node_modules/
package-lock.json
**/package-lock.json
npm-shrinkwrap.json
**/npm-shrinkwrap.json
.npm-cache/
**/.npm-cache/

# Local environment and secrets.
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example
*.pem
*.key
*.p12
*.pfx
*.kdbx
credentials*.json
secrets*.json
*.bak
*.bak-*
agents.md
tasks.md

# Local Control Center install state (generated by `setup install`, not source).
infra/setup/installation-manifest.json

# Logs and temporary output.
*.log
*.tmp
.tmp/
**/.tmp/
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-shm
*.db-wal
.phpunit.result.cache
**/.phpunit.result.cache

# Build/test artifacts.
dist/
dist-cloud/
**/dist/
**/dist-cloud/
**/test-results/
**/playwright-report/
**/blob-report/
**/visual-evidence/
**/.vite/
**/.next/
coverage/
**/coverage/
# Role storage states include live refresh cookies; auth.setup.ts recreates them.
archive-next/e2e/.auth/
.claude/
# transient brainstorm artifacts
.superpowers/
.worktrees/

# Local agent/tool state and test output.
output/
.fallow/
.agents/

# Operating-system and editor metadata.
.DS_Store
**/.DS_Store
Thumbs.db
**/Thumbs.db
Desktop.ini
**/Desktop.ini

# VS Code: keep shared extensions/settings tracked, ignore per-user/local files.
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Git Bash crash dumps (Windows)
*.stackdump
