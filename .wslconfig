[wsl2]
# Fixed DNS and network isolation
GeneratedResolvConf=false
DnsTunneling=false
Firewall=true
# Switch from mirrored (unstable) back to NAT-based routing
NetworkingMode=NAT
# Increase memory for Docker daemon stability
Memory=4GB
Swap=2GB
# CPU allocation
Processors=4
# Fixed vNIC settings to prevent network drops
Virtualization=hyperv
PageReporting=true
NestedVirtualization=true

[interop]
AppendWindowsPath=false
Enabled=true
