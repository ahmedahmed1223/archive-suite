[wsl2]
# Stable NAT mode - no mirrored network issues
NetworkingMode=NAT
# Disable problematic DNS tunneling
DnsTunneling=false
GeneratedResolvConf=false
# Conservative resource allocation to prevent network stalling
Memory=3GB
Swap=1GB
Processors=2
# Disable advanced features that cause drops
NestedVirtualization=false
PageReporting=false
# TCP tuning for stability
TcpKeepAliveTime=60
TcpKeepAliveInterval=10
TcpMaxDataRetransmissions=5

[interop]
AppendWindowsPath=false
Enabled=true

[boot]
systemd=false
