{
  "name": "video-archive-vite",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --configLoader runner",
    "build": "vite build --mode spa --configLoader runner",
    "build:spa": "vite build --mode spa --configLoader runner",
    "build:cloud": "vite build --mode cloud --configLoader runner",
    "build:aistudio": "vite build --mode aistudio --configLoader runner",
    "verify": "node scripts/verify-modules.mjs",
    "visual:matrix": "node scripts/visual-matrix.mjs",
    "test:a11y": "node scripts/run-a11y.mjs",
    "refactor:status": "node scripts/refactor-status.mjs",
    "check": "npm run verify && npm run build:spa",
    "preview": "vite preview --host 127.0.0.1 --configLoader runner"
  },
  "dependencies": {
    "@archive/core": "github:ahmedahmed1223/archive-core#v1.2.1",
    "bcryptjs": "^3.0.3",
    "crypto-js": "^4.2.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-grid-layout": "^2.2.3",
    "sql.js": "^1.14.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
