{
  "name": "@archive/app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --configLoader runner",
    "build": "vite build --mode spa --configLoader runner",
    "build:spa": "vite build --mode spa --configLoader runner",
    "build:cloud": "vite build --mode cloud --configLoader runner",
    "build:aistudio": "vite build --mode aistudio --configLoader runner",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "node scripts/verify-modules.mjs",
    "visual:matrix": "node scripts/visual-matrix.mjs",
    "test:a11y": "vitest run src/__tests__/a11y/",
    "test:a11y:e2e": "node scripts/run-a11y.mjs",
    "audit:ui": "node scripts/run-interactive-audit.mjs",
    "audit:ui:headed": "node scripts/run-interactive-audit.mjs --headed",
    "audit:ui:server": "node scripts/run-interactive-audit.mjs --server",
    "refactor:status": "node scripts/refactor-status.mjs",
    "analyze": "vite build --mode analyze --configLoader runner",
    "size": "node scripts/check-bundle-size.js",
    "check": "pnpm run verify && pnpm run build:spa",
    "preview": "vite preview --host 127.0.0.1 --configLoader runner",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@archive/core": "workspace:1.2.1",
    "@sentry/react": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "cytoscape": "^3.34.0",
    "framer-motion": "^12.40.0",
    "i18next": "^24.0.0",
    "lucide-react": "^1.17.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-grid-layout": "^2.2.3",
    "react-i18next": "^15.0.0",
    "react-resizable": "^4.0.1",
    "sql.js": "^1.14.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^6.0.2",
    "daisyui": "^5.5.23",
    "jsdom": "^29.1.1",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^3.2.0",
    "vitest-axe": "^0.1.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
