# Copy to .env.local and edit before running `pnpm dev`.
# All VITE_* variables are embedded into the built bundle at build time.

# ── Sentry error tracking (optional) ──────────────────────────────────────────
# Set VITE_SENTRY_DSN to enable browser error tracking in the React app.
# Leave empty (default) to disable — the app runs fine without it.
# Sentry is only active in non-DEV builds (beforeSend suppresses dev events).
VITE_SENTRY_DSN=
