# Never bake local env/secrets into the image — compose provides runtime env.
# (php artisan serve strips non-whitelisted env vars from the web process, so a
# baked .env silently wins over compose env — this caused the sqlite-vs-pgsql bug.)
.env
.env.*
!.env.example

# Rebuilt inside the image by composer install
vendor

# Local-only state
node_modules
.git
storage/logs
storage/framework/cache
storage/framework/sessions
storage/framework/views
database/database.sqlite
tests
.phpunit.result.cache

# V1-202: a dev machine running `php artisan` locally regenerates these
# (gitignored, never committed) — baking a stale one into the image makes
# `composer dump-autoload && package:discover` boot the app against a
# manifest that doesn't match the fresh --no-dev vendor/ install, which
# fails with a cryptic "Target class [env] does not exist". Always rebuild
# inside the image instead.
bootstrap/cache/*.php
