APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ARCHIVE_ACCESS_TTL_MINUTES=15
ARCHIVE_REFRESH_TTL_DAYS=14
ARCHIVE_REFRESH_COOKIE=va_refresh
ARCHIVE_SECURE_COOKIES=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Optional Sentry monitoring. Leave DSNs empty/null to disable locally and in tests.
SENTRY_LARAVEL_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_PROFILES_SAMPLE_RATE=
SENTRY_SEND_DEFAULT_PII=false

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Optional read/probe bridge for legacy Windows ODBC DSNs. Disabled by default.
ODBC_ENABLED=false
ODBC_DSN=
ODBC_USERNAME=
ODBC_PASSWORD=
ODBC_TABLE_LIMIT=25

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=archive-collab
REVERB_APP_KEY=archive-collab-key
REVERB_APP_SECRET=archive-collab-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
# AWS_ENDPOINT + AWS_USE_PATH_STYLE_ENDPOINT=true تُستخدم أيضاً لخدمات متوافقة مع S3
# مثل Cloudflare R2 وDigitalOcean Spaces وMinIO وBackblaze B2
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# تخزين Azure Blob (قرص 'azure')
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=
AZURE_STORAGE_PREFIX=

# تخزين Google Cloud Storage (قرص 'gcs'). اتركه فارغاً لاستخدام Application Default Credentials
GOOGLE_CLOUD_KEY_FILE=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_STORAGE_BUCKET=
GOOGLE_CLOUD_STORAGE_PREFIX=

# تخزين Dropbox (قرص 'dropbox')
DROPBOX_ACCESS_TOKEN=
DROPBOX_PREFIX=

# تخزين SFTP (قرص 'sftp')
SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
SFTP_PRIVATE_KEY=
SFTP_ROOT=

# تخزين FTP (قرص 'ftp')
FTP_HOST=
FTP_PORT=21
FTP_USERNAME=
FTP_PASSWORD=
FTP_ROOT=

VITE_APP_NAME="${APP_NAME}"

# Media processing
# MEDIA_PROCESSOR=fake keeps tests/dev offline. Set to real in worker/runtime images.
MEDIA_PROCESSOR=fake
WHISPER_BINARY=whisper-ctranslate2
WHISPER_MODEL=large-v3
WHISPER_LANGUAGE=ar
WHISPER_OUTPUT_FORMAT=vtt
# cpu/int8 is the local-friendly default; override to cuda/float16 on a GPU host.
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# Speaker diarization via pyannote. whisper-ctranslate2 has no --diarize flag —
# it turns on when a non-empty HF_TOKEN (HuggingFace token with access to
# pyannote's gated models) is forwarded as --hf_token.
WHISPER_DIARIZE=false
HF_TOKEN=
MEDIA_WATERMARK_ENABLED=false
MEDIA_WATERMARK_PATH=
MEDIA_WATERMARK_POSITION=bottom-right
MEDIA_WATERMARK_OPACITY=0.85

# Optional broadcast integrations (MOS/MXF). Leave unset to keep the broadcast
# metadata UI in its explicit "configuration required" state.
MOS_ENDPOINT=
MXF_ENDPOINT=
MEDIA_WATERMARK_MARGIN=24
