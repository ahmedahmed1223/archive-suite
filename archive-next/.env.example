# Base URL the Next.js server proxies /api/v1/* to (see next.config.mjs).
ARCHIVE_API_BASE_URL=http://localhost:8000/api/v1

# Reverb (WebSocket push) client config — must match the Laravel API's
# REVERB_* values in archive-laravel/.env. Falls back to heartbeat polling
# when NEXT_PUBLIC_REVERB_APP_KEY is unset.
NEXT_PUBLIC_REVERB_APP_KEY=archive-collab-key
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_REVERB_SCHEME=http

# Optional Sentry browser + server monitoring. Leave empty to disable.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=local
NEXT_PUBLIC_SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

# Archive assistant (server-only). ARCHIVE_COPILOT_ENABLED + ARCHIVE_COPILOT_PROVIDER
# gate the readiness indicator at /copilot; ARCHIVE_COPILOT_API_KEY additionally
# enables the protected /api/copilot/chat endpoint, which calls the Anthropic
# Messages API directly. Keep all of these in the server secret store, never
# NEXT_PUBLIC_*. ARCHIVE_COPILOT_MODEL optionally overrides the default model.
ARCHIVE_COPILOT_ENABLED=false
ARCHIVE_COPILOT_PROVIDER=
ARCHIVE_COPILOT_API_KEY=
ARCHIVE_COPILOT_MODEL=
