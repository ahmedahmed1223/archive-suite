# Base URL the Next.js server proxies /api/v1/* to (see next.config.mjs).
ARCHIVE_API_BASE_URL=http://localhost:8000/api/v1

# Reverb (WebSocket push) client config — must match the Laravel API's
# REVERB_* values in archive-laravel/.env. Falls back to heartbeat polling
# when NEXT_PUBLIC_REVERB_APP_KEY is unset.
NEXT_PUBLIC_REVERB_APP_KEY=archive-collab-key
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_PORT=8080
NEXT_PUBLIC_REVERB_SCHEME=http

# Archive assistant (server-only, Vercel AI SDK). ARCHIVE_COPILOT_ENABLED opts
# in to the protected /api/copilot/chat endpoint and the readiness indicator
# at /copilot; ARCHIVE_COPILOT_PROVIDER selects the model provider
# (anthropic | openai | google | groq | mistral | xai | deepseek | openrouter
# | openai-compatible, defaults to anthropic). Provide the matching provider
# API key below. ARCHIVE_COPILOT_MODEL optionally overrides the default model
# for the selected provider (required for openrouter/openai-compatible, which
# have no default). Keep all of these in the server secret store, never
# NEXT_PUBLIC_*.
ARCHIVE_COPILOT_ENABLED=false
ARCHIVE_COPILOT_PROVIDER=
ARCHIVE_COPILOT_MODEL=

# anthropic (default provider; defaults to claude-sonnet-5)
ANTHROPIC_API_KEY=
# Legacy fallback for ANTHROPIC_API_KEY when provider=anthropic — prefer
# ANTHROPIC_API_KEY in new setups.
ARCHIVE_COPILOT_API_KEY=

# openai (defaults to gpt-5)
OPENAI_API_KEY=

# google (defaults to gemini-2.5-flash)
GOOGLE_GENERATIVE_AI_API_KEY=

# groq (defaults to llama-3.3-70b-versatile)
GROQ_API_KEY=

# mistral (defaults to mistral-large-latest)
MISTRAL_API_KEY=

# xai / Grok (defaults to grok-4)
XAI_API_KEY=

# deepseek (defaults to deepseek-chat)
DEEPSEEK_API_KEY=

# openrouter (routed via the OpenAI-compatible client) — requires
# ARCHIVE_COPILOT_MODEL to be set explicitly (e.g. anthropic/claude-sonnet-5).
OPENROUTER_API_KEY=

# openai-compatible (self-hosted / third-party endpoints, e.g. Ollama, LM
# Studio, vLLM) — requires ARCHIVE_COPILOT_MODEL to be set explicitly.
ARCHIVE_COPILOT_COMPAT_API_KEY=
ARCHIVE_COPILOT_COMPAT_BASE_URL=
