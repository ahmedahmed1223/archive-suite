# Context-relative .dockerignore for archive-server/ scoped builds.
# (Also inherits root .dockerignore when context is the monorepo root.)

node_modules
src/generated/
dist/
*.log
.env
.env.*
!.env.example

# PocketBase runtime data and binary
pocketbase/pb_data

# Deployment & reverse-proxy config (not needed inside the image)
deploy/pgadmin-servers.json
nginx/
k8s/
helm/

# OCR service has its own Dockerfile and build context
ocr-service/

# Test files
**/__tests__
**/*.test.*
**/*.spec.*
coverage/

# Editor & OS
.vscode
.idea
**/.DS_Store
**/Thumbs.db

# Git
.git
.gitignore
