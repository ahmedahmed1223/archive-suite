# archive-server environment variables
# Copy to .env and fill in values before `docker compose up`.
# All vars are optional unless marked REQUIRED.
# Generate secrets: openssl rand -base64 48

# ── Core ──────────────────────────────────────────────────────────────────────
BACKEND=postgres               # postgres | pocketbase
API_PORT=8787                  # TCP port the Node server listens on
NODE_ENV=production            # development | production
APP_BASE_URL=https://example.com  # Public URL (used in password-reset links)

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://archive:CHANGE_ME@postgres:5432/archive  # REQUIRED for BACKEND=postgres
POCKETBASE_URL=http://127.0.0.1:8090  # Base URL of PocketBase instance (BACKEND=pocketbase only)

# ── Auth (REQUIRED for public deployments) ────────────────────────────────────
JWT_AUTH_SECRET=               # Signs login Bearer tokens — openssl rand -base64 48
JWT_SHARE_SECRET=              # Signs /api/share/* share-link tokens
OAUTH_STATE_SECRET=            # Signs Dropbox OAuth CSRF state
JWT_SECRET=                    # Legacy fallback (used if JWT_AUTH_SECRET is absent)
ADMIN_USERNAME=admin           # First-admin username seeded on empty database
ADMIN_PASSWORD=CHANGE_ME       # First-admin password (change immediately after first login)

# ── Storage ───────────────────────────────────────────────────────────────────
FILE_STORE=disk                # disk | s3 | azure | gdrive | dropbox | ftp | smb | sftp | webdav
FILE_STORE_DIR=.archive-files  # Root path for disk storage

# S3-compatible (FILE_STORE=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=                   # Leave empty for Amazon S3; set for R2/MinIO/B2/DO/Wasabi

# ── AI (optional) ─────────────────────────────────────────────────────────────
AI_PROVIDER=                   # openai | anthropic | groq | google | openrouter | ollama | ...
AI_API_KEY=                    # Provider API key (not needed for ollama)
OPENAI_API_KEY=                # OpenAI key for semantic-search embeddings (falls back to AI_API_KEY)

# ── Backups (optional) ────────────────────────────────────────────────────────
BACKUP_ENABLED=false           # Set true to activate the backup scheduler
BACKUP_DIR=backups             # Directory for backup snapshots
BACKUP_ENCRYPTION_KEY=         # AES-256 key for encrypted backups — openssl rand -hex 32

# ── Enterprise backup replication — off-site S3 (optional) ───────────────────
BACKUP_REPLICATION_ENABLED=false          # Set true to enable S3 replication
BACKUP_REPLICATION_BUCKET=               # Target S3 bucket name
BACKUP_REPLICATION_REGION=us-west-2      # Prefer a different region from primary (cross-region DR)
BACKUP_REPLICATION_PREFIX=backups        # S3 key prefix (default: backups)
BACKUP_REPLICATION_ENCRYPTION_KEY=       # AES-256-GCM key (64 hex chars) — openssl rand -hex 32
                                          # Leave empty to store backups unencrypted in S3

# ── Monitoring (optional) ─────────────────────────────────────────────────────
SENTRY_DSN=                    # Sentry project DSN; leave empty to disable
REDIS_URL=                     # Redis URL for caching and media job persistence
