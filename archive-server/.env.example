# archive-server environment variables
# Copy to .env and fill in values before `docker compose up`.
# All vars are optional unless marked REQUIRED.
# Generate secrets: openssl rand -base64 48

# ── Core ──────────────────────────────────────────────────────────────────────
# postgres | pocketbase
BACKEND=postgres
# TCP port the Node server listens on
API_PORT=8787
# development | production
NODE_ENV=production
# Public URL used in password-reset links
APP_BASE_URL=https://example.com

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=archive
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=archive
# REQUIRED for BACKEND=postgres
DATABASE_URL=postgresql://archive:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/archive
# Base URL of PocketBase instance (BACKEND=pocketbase only)
POCKETBASE_URL=http://127.0.0.1:8090

# ── Auth (REQUIRED for public deployments) ────────────────────────────────────
# Public-deploy guard: flips the server into its stricter public posture
# (forces JWT auth, disables the unauthenticated dev surface). Set to 0 only for
# a single-user, localhost-only dev instance.
ARCHIVE_PUBLIC_DEPLOY=1
# Signs login Bearer tokens — openssl rand -base64 48
JWT_AUTH_SECRET=CHANGE_ME_AUTH_SECRET_48_CHARS_MINIMUM_VALUE
# Signs /api/share/* share-link tokens
JWT_SHARE_SECRET=CHANGE_ME_SHARE_SECRET_48_CHARS_MINIMUM_VALUE
# Signs Dropbox OAuth CSRF state
OAUTH_STATE_SECRET=CHANGE_ME_OAUTH_STATE_SECRET_48_CHARS_MINIMUM
# Operator-supplied JWT secret — required when ARCHIVE_PUBLIC_DEPLOY=1 (also used
# as a legacy fallback if JWT_AUTH_SECRET is absent). openssl rand -base64 48
JWT_SECRET=
# First-admin username seeded on empty database
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Storage ───────────────────────────────────────────────────────────────────
# disk | s3 | azure | gdrive | dropbox | ftp | smb | sftp | webdav
FILE_STORE=disk
# Root path for disk storage
FILE_STORE_DIR=.archive-files

# S3-compatible (FILE_STORE=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Leave empty for Amazon S3; set for R2/MinIO/B2/DO/Wasabi
S3_ENDPOINT=

# ── AI (optional) ─────────────────────────────────────────────────────────────
# openai | anthropic | groq | google | openrouter | ollama | ...
AI_PROVIDER=
# Provider API key (not needed for ollama)
AI_API_KEY=
# OpenAI key for semantic-search embeddings (falls back to AI_API_KEY)
OPENAI_API_KEY=

# ── Backups (optional) ────────────────────────────────────────────────────────
# Set true to activate the backup scheduler
BACKUP_ENABLED=false
# Directory for backup snapshots
BACKUP_DIR=backups
# AES-256 key for encrypted backups — openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=

# ── Enterprise backup replication — off-site S3 (optional) ───────────────────
# Set true to enable S3 replication
BACKUP_REPLICATION_ENABLED=false
# Target S3 bucket name
BACKUP_REPLICATION_BUCKET=
# Prefer a different region from primary (cross-region DR)
BACKUP_REPLICATION_REGION=us-west-2
# S3 key prefix (default: backups)
BACKUP_REPLICATION_PREFIX=backups
# AES-256-GCM key (64 hex chars) — openssl rand -hex 32
BACKUP_REPLICATION_ENCRYPTION_KEY=
                                          # Leave empty to store backups unencrypted in S3

# ── Monitoring (optional) ─────────────────────────────────────────────────────
# Sentry project DSN; leave empty to disable
SENTRY_DSN=
# Leave empty to let docker-compose.postgres.yml derive redis:// from REDIS_PASSWORD
REDIS_URL=
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
PGADMIN_EMAIL=admin@example.test
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
