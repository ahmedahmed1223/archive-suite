# Copy to .env and edit before `docker compose up`.

# Public hostname Caddy will request a Let's Encrypt cert for.
# Point this domain's A/AAAA record at the VPS public IP first, then bring
# the stack up. For local dev use DOMAIN=localhost (self-signed cert).
DOMAIN=example.com

# Email shown to Let's Encrypt for renewal warnings.
ACME_EMAIL=admin@example.com

# Which backend the cloud server uses (read by registerCloudProviders + Dockerfile.server).
# PostgreSQL is the supported production default. PocketBase remains available
# for lightweight/legacy deployments by setting BACKEND=pocketbase explicitly.
BACKEND=postgres

# Public production guard. Keep 1 for public deployments. Local-only compose
# overrides set this to 0 for development smoke tests.
ARCHIVE_PUBLIC_DEPLOY=1

# PostgreSQL settings used by docker-compose.postgres.yml.
POSTGRES_USER=archive
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
POSTGRES_DB=archive
DATABASE_URL=postgresql://archive:CHANGE_ME_BEFORE_DEPLOY@postgres:5432/archive

# RPC API port the Node server listens on (internal; nginx proxies /api/* to it).
API_PORT=8787
# Set only for cross-origin dev (SPA on a different port). Leave empty in prod
# where nginx keeps the SPA and API same-origin.
API_CORS_ORIGIN=

# ── Authentication (REQUIRED before exposing the server publicly) ──
# Preferred: set separate secrets per token type for better security.
# Each falls back to JWT_SECRET if absent, so a single JWT_SECRET still works.
# Generate strong secrets with:  openssl rand -base64 48
#
# Signs /api/auth/login tokens (Bearer tokens used by the main app).
JWT_AUTH_SECRET=
# Signs /api/share/* share-link tokens (scoped, read-only public links).
JWT_SHARE_SECRET=
# Signs Dropbox OAuth state parameters (CSRF protection during OAuth flow).
OAUTH_STATE_SECRET=
#
# Legacy: single secret — used as fallback if the specific vars above are absent.
# When JWT_SECRET is set and none of the three vars above are set, a warning is
# logged at startup recommending the migration to separate secrets.
# Leaving it empty is allowed only when ARCHIVE_PUBLIC_DEPLOY=0.
JWT_SECRET=
# Token lifetime in seconds (default 12h).
JWT_TTL_SEC=43200
# Refresh token lifetime in seconds (§20.1, default 30 days). The refresh token
# lives in an HttpOnly cookie scoped to /api/auth and rotates on every use.
REFRESH_EXPIRES_IN_SEC=2592000
# Web Push (§20.2) — generate once with: npx web-push generate-vapid-keys
# Leave empty to keep the feature dormant (push endpoints return 501).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
# Public API (§20.5) — comma-separated allowlist of stores readable via an API
# key on GET /api/public/records. Sensitive stores (users, api_keys, webhooks,
# config…) are NEVER exposed regardless of this value.
PUBLIC_API_STORES=video_items,media_items,document_items,audio_items,image_items
# Scoped public share links (G6): how long a /api/share link stays valid (days).
# Share tokens are signed with JWT_SHARE_SECRET (or JWT_SECRET) and expose a
# read-only, scoped subset.
SHARE_EXPIRY_DAYS=30

# System Control Center (§14.8). Defaults to read-only monitoring. To allow
# start/stop/restart from the admin-only web UI, set CONTROL_AGENT_ACTIONS to
# enabled AND define an explicit service allowlist. Commands are spawned without
# a shell and only for these service entries.
# CONTROL_AGENT_MODE: read-only | docker | linux-native | windows-native
CONTROL_AGENT_MODE=read-only
CONTROL_AGENT_ACTIONS=
# Example:
# CONTROL_AGENT_MODE=linux-native
# CONTROL_AGENT_ACTIONS=enabled
# CONTROL_AGENT_SERVICES=[{"id":"archive-api","name":"Archive API","systemdUnit":"archive-api.service","actions":["restart"]}]
CONTROL_AGENT_SERVICES=

# First-admin seeding: if the users store is empty on startup, an admin is
# created from these so a fresh deploy has a login. Remove after first boot.
ADMIN_USERNAME=admin
# تظهر هذه القيمة في معالج الإعداد لتسهيل أول تسجيل دخول. غيّرها فورًا بعد
# الإعداد الأول ولا تستخدم القيمة النموذجية في أي نشر متاح للعامة.
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Rate limiting (per client IP, sliding window) ──
# Defaults: 600 rpc/min, 10 login/min (brute-force defense), 60s window.
RATE_LIMIT_RPC_MAX=600
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# ── Record size limit (Postgres adapter) ──
# Maximum JSON size (bytes) for a single stored record. Requests that exceed
# this are rejected with HTTP 413 before touching the database.
# Default: 10 MB. Increase only if you store very large binary-embedded fields.
MAX_RECORD_BYTES=10485760

# ── File storage (media blobs / thumbnails) ──
# FILE_STORE selects the FileStore backend behind /api/files/*:
#   disk    (default) — local disk under FILE_STORE_DIR.
#   dropbox           — a Dropbox app folder (DROPBOX_* below).
#   s3/azure/gdrive/dropbox — cloud object/file stores.
#   ftp/smb/sftp/webdav     — local or remote file servers.
# In every case the SPA only ever talks to /api/files/* — credentials and the
# concrete provider never reach the browser.
FILE_STORE=disk
FILE_STORE_DIR=.archive-files
# Docker Compose overrides FILE_STORE_DIR with this container path so uploaded
# files land in the persistent server_files volume.
DOCKER_FILE_STORE_DIR=/app/files

# Dropbox (FILE_STORE=dropbox). Token stays server-side.
DROPBOX_ACCESS_TOKEN=
# Root path inside Dropbox (empty = app-folder root, e.g. /archive).
DROPBOX_ROOT_PATH=

# S3-compatible (FILE_STORE=s3). One adapter, many providers — set S3_ENDPOINT
# (and S3_FORCE_PATH_STYLE for MinIO/self-hosted). Leave S3_ENDPOINT empty for
# Amazon S3. Provider endpoint cheatsheet:
#   Amazon S3        : (leave S3_ENDPOINT empty), set S3_REGION
#   Cloudflare R2    : https://<account_id>.r2.cloudflarestorage.com  (region auto)
#   Backblaze B2     : https://s3.<region>.backblazeb2.com
#   DigitalOcean     : https://<region>.digitaloceanspaces.com
#   Wasabi           : https://s3.<region>.wasabisys.com
#   Google Cloud     : https://storage.googleapis.com   (S3 interop keys)
#   MinIO/self-hosted: http(s)://host:9000  + S3_FORCE_PATH_STYLE=true
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
# Optional key prefix (folder) inside the bucket, and presigned-URL lifetime (s).
S3_PREFIX=

# Azure Blob Storage (FILE_STORE=azure). Easiest: a connection string from the
# storage account. Alternatively set AZURE_STORAGE_ACCOUNT + AZURE_STORAGE_KEY,
# or AZURE_STORAGE_ACCOUNT_URL + AZURE_STORAGE_SAS.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=
# Optional alternatives to the connection string:
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_SAS=
# Optional blob-name prefix (folder) + SAS download-URL lifetime (s).
AZURE_STORAGE_PREFIX=
AZURE_URL_EXPIRES_IN=3600

# Google Drive (FILE_STORE=gdrive). Uses a SERVICE ACCOUNT (no interactive
# OAuth): create one in Google Cloud, enable the Drive API, then SHARE the
# target Drive folder with the service-account email. Files are stored flat in
# that folder with the FileStore key as the file name.
GDRIVE_FOLDER_ID=
# The service-account JSON, inlined as one line (or set GOOGLE creds another way).
GDRIVE_CREDENTIALS=
# Optional file-name prefix (folder-like grouping inside the Drive folder).
GDRIVE_PREFIX=
S3_URL_EXPIRES_IN=3600

# FTP / FTPS (FILE_STORE=ftp). Blobs live on a remote FTP server; the SPA still
# talks only to /api/files/*. Set FTP_SECURE=true for explicit FTPS.
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=
FTP_SECURE=false
FTP_ROOT=/

# SMB / CIFS (FILE_STORE=smb). Blobs live on a Windows/Samba share. SMB_SHARE is
# the UNC path, e.g. \\\\fileserver\\archive. SMB_ROOT is an optional sub-folder.
SMB_SHARE=
SMB_DOMAIN=WORKGROUP
SMB_USERNAME=
SMB_PASSWORD=
SMB_ROOT=

# SFTP / SSH (FILE_STORE=sftp). Use either a password or a private key.
SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
# PEM/OpenSSH key content; keep multiline values in a secret manager in production.
SFTP_PRIVATE_KEY=
SFTP_PASSPHRASE=
SFTP_ROOT=/

# WebDAV (FILE_STORE=webdav). Authentication is optional for trusted local
# servers; otherwise use username/password or a bearer token.
WEBDAV_URL=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=
WEBDAV_BEARER_TOKEN=
WEBDAV_ROOT=/

# ── AI (optional, server-side only — keys NEVER reach the SPA) ──
# Unified multi-provider layer. AI_PROVIDER is one of:
#   openrouter | openai | google | anthropic | groq | together | deepseek
#   | mistral | xai | ollama
# OpenRouter is a single gateway to most models. Leave AI_PROVIDER empty to
# disable AI. ollama needs no key (local). AI_MODEL/AI_BASE_URL override defaults.
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=
AI_BASE_URL=
# Implementation: "sdk" (default — Vercel AI SDK, validated JSON via Zod) or
# "manual" (zero-dependency hand-rolled fetch client). SDK falls back to manual
# automatically if it can't construct the chosen provider.
AI_IMPL=sdk

# ── Speech-to-text / transcription (optional, independent of the chat AI) ──
# TRANSCRIBE_PROVIDER one of: openai | groq | whisper-local
#   openai/groq    → hosted Whisper API (set TRANSCRIBE_API_KEY)
#   whisper-local  → self-hosted container, no key (set TRANSCRIBE_BASE_URL).
#                    Start it with: docker compose --profile whisper up -d
# Leave empty to disable transcription.
TRANSCRIBE_PROVIDER=
TRANSCRIBE_API_KEY=
TRANSCRIBE_MODEL=
TRANSCRIBE_BASE_URL=http://whisper:8000/v1

# ── Email / SMTP (for password reset — optional) ──
# If SMTP_HOST is unset, reset URLs are logged to the server console instead of
# being emailed. This is safe for development but must be configured for production.
# Example providers: smtp.gmail.com (587), smtp.sendgrid.net (587), mail.smtp2go.com (587)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Archive Suite <noreply@example.com>
# Public base URL used to build the reset link in the email. Defaults to the
# request origin (Host header) if unset. Set explicitly in production.
APP_BASE_URL=https://your-domain.com

# ── Sentry error tracking (optional) ──────────────────────────────────────────
# Set SENTRY_DSN to a Sentry DSN string to enable server-side error tracking.
# Leave empty (default) to disable — the server runs fine without it.
SENTRY_DSN=

# pgAdmin (enabled by default in docker-compose.postgres.yml).
# PGADMIN_PASSWORD logs into the pgAdmin web UI. POSTGRES_PASSWORD authenticates
# the Archive Postgres server saved inside pgAdmin; they are deliberately separate.
# The pgadmin-init job reconciles both values even when pgadmin_data already exists.
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD

# Grafana (enabled by default in docker-compose.postgres.yml)
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# PaddleOCR service (enabled by default in docker-compose.postgres.yml)
OCR_SERVICE_URL=http://ocr:8788
OCR_LANG=ar
OCR_USE_GPU=false
OCR_MAX_FILE_MB=20

# Redis (enabled by default in docker-compose.postgres.yml)
# Set REDIS_PASSWORD and let docker-compose.postgres.yml build REDIS_URL, or set
# REDIS_URL explicitly to any Redis-compatible URL.
REDIS_URL=
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Semantic search (optional -- requires OpenAI API key and pgvector extension)
# Run the 20260608120000_add_pgvector migration to enable, then set the key below.
# Uses OPENAI_API_KEY preferentially; falls back to AI_API_KEY.
# Leave blank to disable (app works fine without embeddings).
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# ── Workflow due-date reminders (optional) ────────────────────────────────────
# Set WORKFLOW_DUE_REMINDERS_ENABLED=true to send push alerts for upcoming/overdue
# records. Alerts fire at most once per day per record. Requires Web Push (VAPID).
WORKFLOW_DUE_REMINDERS_ENABLED=true
# How often to check for due dates (default: 1 hour).
WORKFLOW_DUE_CHECK_HOURS=1

# ── Scheduled backups (optional) ──────────────────────────────────────────────
# Set BACKUP_ENABLED=true to activate the server-side backup scheduler.
# Backups are gzipped JSON snapshots of the entire archive, written to BACKUP_DIR.
# Retention policy: keep daily for BACKUP_RETENTION_DAYS, one-per-week for
# BACKUP_RETENTION_WEEKS weeks, one-per-month for BACKUP_RETENTION_MONTHS months.
BACKUP_ENABLED=true
BACKUP_DIR=backups
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=7
BACKUP_RETENTION_WEEKS=4
BACKUP_RETENTION_MONTHS=3
# AES-256-CBC encryption key for backup files (leave empty to disable encryption).
# Generate a strong key with: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=
