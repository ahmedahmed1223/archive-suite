{
  "name": "archive-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Production (server) edition of the Video Archive app: cloud-pocketbase adapters behind @archive/core ports + PocketBase + Docker.",
  "scripts": {
    "start": "tsx src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "tsx scripts/verify-config.mjs && tsx scripts/verify-server-config.mjs && tsx scripts/verify-server.mjs && tsx scripts/verify-postgres-adapter.mjs && tsx scripts/verify-api.mjs && tsx scripts/verify-notifications.mjs && tsx scripts/verify-workflow.mjs && tsx scripts/verify-apikeys.mjs && tsx scripts/verify-auth.mjs && tsx scripts/verify-realtime.mjs && tsx scripts/verify-ai.mjs && tsx scripts/verify-ai-sdk.mjs && tsx scripts/verify-export.mjs && tsx scripts/verify-media.mjs && tsx scripts/verify-files-dropbox.mjs && tsx scripts/verify-files-s3.mjs && tsx scripts/verify-files-azure.mjs && tsx scripts/verify-files-gdrive.mjs && tsx scripts/verify-share.mjs && tsx scripts/verify-admin-config.mjs && tsx scripts/verify-db-provider.mjs && tsx scripts/verify-deployment.mjs && tsx scripts/verify-backup.mjs",
    "verify:backup": "tsx scripts/verify-backup.mjs",
    "verify:ai": "tsx scripts/verify-ai.mjs && tsx scripts/verify-ai-sdk.mjs",
    "verify:export": "tsx scripts/verify-export.mjs",
    "verify:media": "tsx scripts/verify-media.mjs",
    "verify:dropbox": "tsx scripts/verify-files-dropbox.mjs",
    "verify:s3": "tsx scripts/verify-files-s3.mjs",
    "verify:azure": "tsx scripts/verify-files-azure.mjs",
    "verify:gdrive": "tsx scripts/verify-files-gdrive.mjs",
    "verify:share": "tsx scripts/verify-share.mjs",
    "verify:config": "tsx scripts/verify-config.mjs",
    "verify:admin": "tsx scripts/verify-admin-config.mjs",
    "verify:pocketbase": "tsx scripts/verify-server.mjs",
    "verify:postgres": "tsx scripts/verify-postgres-adapter.mjs",
    "verify:api": "tsx scripts/verify-api.mjs && tsx scripts/verify-notifications.mjs",
    "verify:notifications": "tsx scripts/verify-notifications.mjs",
    "verify:workflow": "tsx scripts/verify-workflow.mjs",
    "verify:apikeys": "tsx scripts/verify-apikeys.mjs",
    "verify:auth": "tsx scripts/verify-auth.mjs",
    "verify:db-provider": "tsx scripts/verify-db-provider.mjs",
    "verify:deployment": "tsx scripts/verify-deployment.mjs",
    "verify:cloud-live": "tsx scripts/verify-cloud-live.mjs",
    "check": "pnpm run verify",
    "db:provider": "node scripts/set-db-provider.mjs",
    "prisma:generate": "node scripts/set-db-provider.mjs && prisma generate",
    "prisma:migrate": "node scripts/set-db-provider.mjs && prisma migrate deploy",
    "prisma:migrate:dev": "node scripts/set-db-provider.mjs && prisma migrate dev",
    "load-test": "k6 run load-tests/baseline.js",
    "load-test:peak": "k6 run --env TARGET=peak load-tests/baseline.js",
    "load-test:spike": "k6 run --env TARGET=spike load-tests/baseline.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/groq": "^3.0.39",
    "@ai-sdk/mistral": "^3.0.37",
    "@ai-sdk/openai": "^3.0.67",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@archive/core": "workspace:1.2.1",
    "@aws-sdk/client-s3": "^3.1058.0",
    "@aws-sdk/s3-request-presigner": "^3.1058.0",
    "@azure/storage-blob": "^12.31.0",
    "@googleapis/drive": "^20.2.0",
    "@marsaud/smb2": "^0.18.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.56.0",
    "ai": "^6.0.193",
    "basic-ftp": "^5.0.5",
    "bcryptjs": "^3.0.3",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.4.1",
    "nodemailer": "^6.9.16",
    "otpauth": "^9.5.1",
    "pdf-lib": "^1.17.1",
    "pino": "^9.6.0",
    "pocketbase": "^0.27.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "ssh2-sftp-client": "^12.1.1",
    "tsx": "^4.22.4",
    "web-push": "^3.6.7",
    "webdav": "^5.10.0",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "prisma": "^7.8.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
