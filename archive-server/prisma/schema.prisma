// Postgres schema for the archive cloud backend.
//
// Generic-row design: ONE table holds every store's rows, keyed by
// (store, uid). Mirrors the PocketBase adapter's `{ uid, data, syncVersion,
// lastModifiedBy }` shape exactly so snapshot/replaceAll work identically
// on both backends and the SPA's payload format stays unchanged.
//
// We give up a little Prisma-level type safety (data is Json) but gain:
//   - A single migration that fits every store the SPA invents.
//   - Free support for the archive's dynamic custom-field model — anything
//     the SPA can put in a record lands in JSONB unchanged.
//   - GIN-index ready: `CREATE INDEX ON storage_rows USING gin (data jsonb_path_ops)`
//     can be added in a follow-up migration without touching app code.
//   - 1:1 parity with the PB adapter so importing a backup between backends
//     is a no-transform copy.

generator client {
  // Prisma 7: the Rust-free `prisma-client` provider. It emits TypeScript
  // (no JS option), so the server runs under `tsx` (see package.json start).
  // moduleFormat=esm matches the package "type": "module"; importFileExtension
  // ="js" makes the generated client's internal imports use .js specifiers
  // that tsx resolves to the sibling .ts files.
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  runtime             = "nodejs"
  moduleFormat        = "esm"
  importFileExtension = "js"
}

datasource db {
  // Prisma 7 keeps the URL in prisma.config.mjs, not in schema.prisma, and does
  // NOT allow env() in `provider`. So the engine is fixed here at GENERATE time:
  // `npm run prisma:generate` runs scripts/set-db-provider.mjs first, which
  // rewrites this line from DATABASE_PROVIDER (postgresql|mysql|sqlite|sqlserver,
  // default postgresql). Switching engines = set the env var, re-generate +
  // migrate, restart. Admin config + the SPA already capture the engine + URL.
  provider = "postgresql"
}

model StorageRow {
  store          String
  uid            String
  data           Json
  syncVersion    Int?
  lastModifiedBy Json?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  // pgvector embedding (1536 dims = text-embedding-3-small).
  // Nullable — rows without embeddings are skipped in semantic search.
  // Prisma uses Unsupported for pgvector types since there is no native mapping.
  embedding      Unsupported("vector(1536)")?

  // Composite primary key — uid is unique *within* a store, not globally.
  @@id([store, uid])
  // Lookups by store alone (getAll, replaceAll's per-store wipe).
  @@index([store])
  // Index for filtering by timestamps
  @@index([createdAt])
  // Index for filtering by syncVersion (used in sync operations)
  @@index([syncVersion])
  @@map("storage_rows")
}

model ShareRevocation {
  jti       String   @id
  revokedAt DateTime @default(now())

  @@map("share_revocations")
}

// ─── Typed Schema Evolution ────────────────────────────────────────────────
// These typed tables are the foundation for migrating away from the generic
// StorageRow/JSONB model. They run alongside StorageRow — no breaking change.
// Dual-write: when TYPED_SCHEMA=true, new records are written to both.

/// Strongly-typed user record (parallel to StorageRow store="users")
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String?
  email        String?  @unique
  role         String   @default("viewer")
  isActive     Boolean  @default(true)
  passwordHash String
  totpSecret   String?
  totpEnabled  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([role])
  @@index([isActive])
  @@map("typed_users")
}

/// Strongly-typed archive item (parallel to StorageRow store="videos"/"documents"/etc.)
model ArchiveItem {
  id            String    @id @default(cuid())
  store         String // original store name ("videos", "documents", etc.)
  title         String
  description   String?
  documentType  String? // pdf | image | video | audio | document
  mimeType      String?
  fileKey       String? // storage key for the file
  fileSizeBytes BigInt?
  pageCount     Int?
  tags          String[] // text array
  categoryId    String?
  ocrText       String?
  summary       String?
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  archivedAt    DateTime? @map("archived_at") // set by retention sweep when action="archive"
  syncVersion   Int       @default(0)
  ownerId       String? // references typed_users.id
  metadata      Json? // flexible overflow for extra fields
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([store])
  @@index([isDeleted])
  @@index([createdAt])
  @@index([store, isDeleted])
  @@index([categoryId])
  @@index([archivedAt])
  @@map("typed_archive_items")
}

/// Version history snapshot for any record (store + uid pair).
/// Written fire-and-forget after every put() call; read by the DetailPage
/// "السجل التاريخي" tab and the /api/records/:uid/versions REST endpoint.
model RecordVersion {
  id        BigInt   @id @default(autoincrement())
  store     String
  recordUid String   @map("record_uid")
  version   Int      @default(1)
  snapshot  Json
  userId    String?  @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([store, recordUid])
  @@map("record_versions")
}

/// Content type registry (replaces hardcoded type lists)
model ContentType {
  id        String   @id @default(cuid())
  name      String   @unique
  label     String // Arabic display name
  icon      String?
  color     String?
  isBuiltIn Boolean  @default(false)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([isActive])
  @@map("typed_content_types")
}

/// Saved search filters / Smart Collections
/// isLive=true → the SPA re-runs the query on every visit and keeps results fresh.
model SavedFilter {
  id        String   @id @default(cuid())
  name      String
  query     Json
  isLive    Boolean  @default(false) @map("is_live")
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ownerId])
  @@map("saved_filters")
}

/// Outgoing webhooks — fired on record.created / record.updated / record.deleted.
/// Each delivery is signed with HMAC-SHA256 using the stored secret.
model Webhook {
  id        String   @id @default(uuid())
  url       String
  events    String[]
  secret    String
  active    Boolean  @default(true)
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ownerId])
  @@map("webhooks")
}

/// Per-user email notification preferences.
/// Created on first access (upsert); defaults match the model defaults.
model NotificationPreference {
  id             String  @id @default(cuid())
  userId         String  @unique @map("user_id")
  emailOnShare   Boolean @default(true) @map("email_on_share")
  emailOnUpload  Boolean @default(false) @map("email_on_upload")
  emailOnMention Boolean @default(true) @map("email_on_mention")
  pushOnShare    Boolean @default(true) @map("push_on_share")
  pushOnUpload   Boolean @default(true) @map("push_on_upload")
  pushOnMention  Boolean @default(true) @map("push_on_mention")
  pushOnSystem   Boolean @default(true) @map("push_on_system")

  @@map("notification_preferences")
}

/// API key (§20.5) — programmatic read access for external systems,
/// separate from user JWTs. Only the SHA-256 hash is stored; the plain key
/// is shown exactly once at creation time.
model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique @map("key_hash")
  prefix     String
  scopes     String[]
  ownerId    String    @map("owner_id")
  active     Boolean   @default(true)
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([ownerId])
  @@map("api_keys")
}

/// Web Push subscription (§20.2) — one row per browser/device endpoint.
/// Dead endpoints (HTTP 404/410 from the push service) are deleted on send.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("push_subscriptions")
}

/// Activity log — every create/update/delete/restore/move/bulk op (§18.1).
/// Mirrors the client-side IndexedDB `activity_log` store so cloud syncs land here.
/// `before`/`after` are full JSONB snapshots; `diff` is field-level { key: { before, after } }.
model ActivityLog {
  id         String    @id
  timestamp  DateTime  @default(now())
  userId     String    @map("user_id")
  userName   String    @map("user_name")
  userRole   String?   @map("user_role")
  sessionId  String?   @map("session_id")
  action     String
  targetType String    @map("target_type")
  targetId   String?   @map("target_id")
  targetName String    @default("") @map("target_name")
  before     Json?
  after      Json?
  diff       Json?
  relatedIds Json?     @map("related_ids")
  undoable   Boolean   @default(false)
  undone     Boolean   @default(false)
  undoneBy   String?   @map("undone_by")
  undoneAt   DateTime? @map("undone_at")
  context    Json?

  @@index([timestamp])
  @@index([userId])
  @@index([targetType])
  @@index([action])
  @@index([targetId])
  @@map("activity_log")
}

/// Derived files produced by server-side format conversion (§16.15).
/// One row per output file; linked to the source item via sourceItemId
/// and to the triggering media job via jobId. Status tracks the job lifecycle.
/// Deletion of a derived file should also call FileStore.remove(outputKey).
model DerivedFile {
  id             String    @id @default(cuid())
  sourceItemId   String?   @map("source_item_id")
  sourceKey      String    @map("source_key")
  outputKey      String?   @map("output_key")
  conversionType String    @map("conversion_type")
  label          String    @default("")
  mimeType       String?   @map("mime_type")
  fileSizeBytes  BigInt?   @map("file_size_bytes")
  status         String    @default("pending")
  jobId          String?   @map("job_id")
  errorMessage   String?   @map("error_message")
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  completedAt    DateTime? @map("completed_at")

  @@index([sourceItemId])
  @@index([sourceKey])
  @@index([status])
  @@index([jobId])
  @@map("derived_files")
}

/// Email invitations for scoped share links (§16.7).
/// The signed token remains stateless; this table records delivery/audit state.
model ShareInvitation {
  id                String    @id
  email             String
  title             String    @default("")
  message           String    @default("")
  scope             Json
  permission        String    @default("view")
  shareJti          String?   @map("share_jti")
  sharePath         String    @map("share_path")
  shareUrl          String    @map("share_url")
  passwordProtected Boolean   @default(false) @map("password_protected")
  expiresAt         DateTime? @map("expires_at")
  invitedByUserId   String?   @map("invited_by_user_id")
  invitedByUsername String?   @map("invited_by_username")
  status            String    @default("created")
  emailSentAt       DateTime? @map("email_sent_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([shareJti])
  @@index([status])
  @@map("share_invitations")
}

/// Comments submitted through public share links (§16.7).
model ShareComment {
  id         String   @id
  itemId     String   @map("item_id")
  text       String
  authorName String   @map("author_name")
  authorType String   @default("share_link") @map("author_type")
  shareJti   String?  @map("share_jti")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([itemId])
  @@index([shareJti])
  @@map("share_comments")
}

/// Manual semantic relations between archive items (§18.5).
/// `type` is one of: is_part_of / contains / references / depends_on /
///   related_to / alternative_of / copy_of / precedes / follows.
/// Bidirectional types (related_to, alternative_of) store a single canonical
/// row (sourceId ≤ targetId alphabetically) to avoid duplicates.
model ItemRelation {
  id        String   @id @default(cuid())
  sourceId  String   @map("source_id")
  targetId  String   @map("target_id")
  type      String
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")
  note      String?

  @@unique([sourceId, targetId, type])
  @@index([sourceId])
  @@index([targetId])
  @@map("item_relations")
}

/// Retention rules for the archive (§22 retention policy).
/// Each rule defines a lifetime for items matching its scope.
/// action="archive" → set archivedAt on the item.
/// action="delete"  → secureOverwrite the file then delete the row.
/// The daily sweep is triggered by scanRetention() in src/retention/retentionPolicy.js.
/// TODO: wire the sweep to a setInterval in src/index.js (24-hour cadence).
model RetentionRule {
  id           String   @id @default(cuid())
  name         String
  scope        String   @default("all") // "all" | "type:<typeId>" | "tag:<tag>"
  lifetimeDays Int      @map("lifetime_days")
  action       String   @default("archive") // "archive" | "delete"
  active       Boolean  @default(true)
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@index([scope])
  @@map("retention_rules")
}
