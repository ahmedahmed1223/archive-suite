{
  "openapi": "3.1.0",
  "info": {
    "title": "Archive Suite API Contract",
    "version": "0.1.0",
    "description": "Framework-neutral API contract for the Laravel API and Next.js migration. The current Node server is the reference implementation until Laravel reaches parity."
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "Versioned API base"
    },
    {
      "url": "/api",
      "description": "Legacy-compatible API base"
    }
  ],
  "tags": [
    { "name": "Health" },
    { "name": "Auth" },
    { "name": "Records" },
    { "name": "Search" },
    { "name": "Files" },
    { "name": "Folders" },
    { "name": "Media" },
    { "name": "Rights" },
    { "name": "Share" },
    { "name": "Ingest" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Server and backend health",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Health information",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Authenticate a user",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/AuthSuccess" },
          "401": { "$ref": "#/components/responses/Error" },
          "429": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Return the current authenticated user",
        "operationId": "getCurrentUser",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Current user",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/OkEnvelope" },
                    {
                      "type": "object",
                      "required": ["user"],
                      "properties": {
                        "user": { "$ref": "#/components/schemas/User" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Rotate the HttpOnly refresh cookie and issue a new access token",
        "operationId": "refreshSession",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": { "$ref": "#/components/responses/AuthSuccess" },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Revoke the current session",
        "operationId": "logout",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/records": {
      "get": {
        "tags": ["Records"],
        "summary": "List records from a store",
        "operationId": "listRecords",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "parameters": [
          {
            "name": "store",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 200, "default": 50 }
          }
        ],
        "responses": {
          "200": {
            "description": "Record page",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RecordListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/records/{id}": {
      "get": {
        "tags": ["Records"],
        "summary": "Read a single record by id",
        "operationId": "getRecord",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "store",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Record",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/OkEnvelope" },
                    {
                      "type": "object",
                      "required": ["record"],
                      "properties": {
                        "record": { "$ref": "#/components/schemas/ArchiveRecord" }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/records/bulk": {
      "post": {
        "tags": ["Records"],
        "summary": "Bulk upsert records for migration and sync compatibility",
        "operationId": "bulkUpsertRecords",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BulkRecordsRequest" }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/search": {
      "get": {
        "tags": ["Search"],
        "summary": "Search archive records",
        "operationId": "searchRecords",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "parameters": [
          { "name": "q", "in": "query", "schema": { "type": "string" } },
          { "name": "store", "in": "query", "schema": { "type": "string" } },
          { "name": "cursor", "in": "query", "schema": { "type": "string" } },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
          },
          { "name": "semantic", "in": "query", "schema": { "type": "boolean", "default": false } }
        ],
        "responses": {
          "200": {
            "description": "Search result page",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SearchResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/files": {
      "get": {
        "tags": ["Files"],
        "summary": "List files in the active file store",
        "operationId": "listFiles",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Files",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FileListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/files/browser": {
      "get": {
        "tags": ["Files"],
        "summary": "Browse a virtual file-store path",
        "operationId": "browseFiles",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "parameters": [
          { "name": "path", "in": "query", "schema": { "type": "string", "default": "" } },
          { "name": "query", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Directory listing",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FileBrowserResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/files/{key}": {
      "get": {
        "tags": ["Files"],
        "summary": "Download or stream a file through the API",
        "operationId": "getFile",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/FileKey" }],
        "responses": {
          "200": { "description": "Binary file stream" },
          "401": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      },
      "put": {
        "tags": ["Files"],
        "summary": "Upload or replace a file by key",
        "operationId": "putFile",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/FileKey" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": { "type": "string", "format": "binary" }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/FileWriteSuccess" },
          "201": { "$ref": "#/components/responses/FileWriteSuccess" },
          "401": { "$ref": "#/components/responses/Error" }
        }
      },
      "delete": {
        "tags": ["Files"],
        "summary": "Delete a file by key",
        "operationId": "deleteFile",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/FileKey" }],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "401": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/folders": {
      "get": {
        "tags": ["Folders"],
        "summary": "List logical archive folders",
        "operationId": "listFolders",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Folders",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FolderListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/rights": {
      "get": {
        "tags": ["Rights"],
        "summary": "Fetch a rights record by archive item id",
        "operationId": "getRightsByItem",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "parameters": [
          {
            "name": "itemId",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Rights record",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RightsRecordResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      },
      "post": {
        "tags": ["Rights"],
        "summary": "Create or upsert a rights record",
        "operationId": "upsertRights",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RightsRecordInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Rights record saved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RightsRecordResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/rights/expiring": {
      "get": {
        "tags": ["Rights"],
        "summary": "List rights records expiring soon",
        "operationId": "listExpiringRights",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "parameters": [
          {
            "name": "days",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 365, "default": 30 }
          }
        ],
        "responses": {
          "200": {
            "description": "Expiring rights",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RightsRecordListResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/rights/{itemId}/enforcement": {
      "get": {
        "tags": ["Rights"],
        "summary": "Return rights enforcement status for an item",
        "operationId": "getRightsEnforcement",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Enforcement summary",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RightsEnforcementResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/media/jobs": {
      "get": {
        "tags": ["Media"],
        "summary": "List media processing workflows",
        "operationId": "listMediaWorkflows",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": { "type": "string", "enum": ["queued", "processing", "completed", "failed"] }
          },
          {
            "name": "recordId",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
          }
        ],
        "responses": {
          "200": {
            "description": "List of media workflows",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/OkEnvelope" },
                    {
                      "type": "object",
                      "required": ["jobs"],
                      "properties": {
                        "jobs": {
                          "type": "array",
                          "items": { "$ref": "#/components/schemas/MediaJob" }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      },
      "post": {
        "tags": ["Media"],
        "summary": "Queue a media processing workflow",
        "operationId": "queueMediaWorkflow",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MediaJobRequest" }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Media workflow queued",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MediaJobResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/media/jobs/{id}": {
      "get": {
        "tags": ["Media"],
        "summary": "Read media workflow status",
        "operationId": "getMediaWorkflow",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Media workflow status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MediaJobResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/share": {
      "post": {
        "tags": ["Share"],
        "summary": "Create a scoped public share link",
        "operationId": "createShare",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateShareRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Share created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateShareResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/share/{token}": {
      "get": {
        "tags": ["Share"],
        "summary": "Read a public share payload",
        "operationId": "getShare",
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Share payload",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SharePayloadResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/ingest/scan": {
      "post": {
        "tags": ["Ingest"],
        "summary": "Scan ingest directory and create archive records",
        "operationId": "scanIngest",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Ingest scan result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IngestScanResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/ingest/ftp/pull": {
      "post": {
        "tags": ["Ingest"],
        "summary": "Pull files from FTP source and create archive records",
        "operationId": "ftpPullIngest",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/FtpPullRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "FTP pull and ingest result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IngestScanResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" },
          "422": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/ingest/smb/pull": {
      "post": {
        "tags": ["Ingest"],
        "summary": "Pull files from SMB source and create archive records",
        "operationId": "smbPullIngest",
        "security": [{ "bearerAuth": [] }, { "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SmbPullRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "SMB pull and ingest result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/IngestScanResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Error" },
          "422": { "$ref": "#/components/responses/Error" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "va_refresh"
      }
    },
    "parameters": {
      "FileKey": {
        "name": "key",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      }
    },
    "responses": {
      "Ok": {
        "description": "Success",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/OkEnvelope" }
          }
        }
      },
      "Error": {
        "description": "Error response",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
          }
        }
      },
      "AuthSuccess": {
        "description": "Authenticated session",
        "headers": {
          "Set-Cookie": {
            "description": "HttpOnly refresh cookie when cookie auth is enabled",
            "schema": { "type": "string" }
          }
        },
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/AuthResponse" }
          }
        }
      },
      "FileWriteSuccess": {
        "description": "File write result",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/FileWriteResponse" }
          }
        }
      }
    },
    "schemas": {
      "OkEnvelope": {
        "type": "object",
        "required": ["ok"],
        "properties": {
          "ok": { "const": true }
        }
      },
      "ErrorEnvelope": {
        "type": "object",
        "required": ["ok", "error"],
        "properties": {
          "ok": { "const": false },
          "error": { "type": "string" },
          "code": { "type": "string" },
          "details": {}
        }
      },
      "HealthResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/OkEnvelope" },
          {
            "type": "object",
            "required": ["backend", "engine", "uptimeSec"],
            "properties": {
              "backend": { "type": "string" },
              "engine": { "type": "string" },
              "uptimeSec": { "type": "integer" },
              "version": { "type": "string" },
              "authRequired": { "type": "boolean" },
              "db": {
                "type": "object",
                "properties": {
                  "ok": { "type": "boolean" },
                  "latencyMs": { "type": "number" },
                  "error": { "type": "string" }
                }
              }
            }
          }
        ]
      },
      "LoginRequest": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": { "type": "string", "minLength": 1 },
          "password": { "type": "string", "minLength": 1 },
          "totp": { "type": "string" },
          "rememberMe": { "type": "boolean", "default": false }
        }
      },
      "AuthResponse": {
        "allOf": [
          { "$ref": "#/components/schemas/OkEnvelope" },
          {
            "type": "object",
            "required": ["user"],
            "properties": {
              "token": { "type": "string" },
              "user": { "$ref": "#/components/schemas/User" }
            }
          }
        ]
      },
      "User": {
        "type": "object",
        "required": ["id", "username", "role"],
        "properties": {
          "id": { "type": "string" },
          "username": { "type": "string" },
          "displayName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "role": { "type": "string", "enum": ["admin", "editor", "viewer"] },
          "totpEnabled": { "type": "boolean" },
          "totpRecoveryCodesRemaining": { "type": "integer" }
        }
      },
      "ArchiveRecord": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string" },
          "uid": { "type": "string" },
