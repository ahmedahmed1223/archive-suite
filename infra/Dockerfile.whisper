FROM python:3.13.14-slim@sha256:6771159cd4fa5d9bba1258caf0b82e6b73458c694d178ad97c5e925c2d0e1a91

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install --no-cache-dir \
    openai-whisper==20250625 \
    flask==3.1.3 \
    python-dotenv==1.2.2

RUN mkdir -p /app/models && \
    python -c "import whisper; whisper.load_model('base', download_root='/app/models')"

COPY whisper_server.py /app/

RUN useradd -r -u 1000 -m -d /home/whisperuser whisperuser && \
    chown -R whisperuser:whisperuser /app
USER 1000:1000

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --retries=3 --start-period=30s \
  CMD curl -f http://localhost:8000/health || exit 1

CMD ["python", "whisper_server.py"]
