FROM python:3.13.14-slim@sha256:6771159cd4fa5d9bba1258caf0b82e6b73458c694d178ad97c5e925c2d0e1a91

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install --no-cache-dir \
    openai-whisper \
    flask \
    python-dotenv

RUN mkdir -p /app/models && \
    python -c "import whisper; whisper.load_model('base', download_root='/app/models')"

COPY whisper_server.py /app/

EXPOSE 8000

CMD ["python", "whisper_server.py"]
