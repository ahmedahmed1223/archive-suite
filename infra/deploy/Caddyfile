# Caddyfile — automatic HTTPS via Let's Encrypt + reverse proxy to the
# Next.js app. DOMAIN and ACME_EMAIL come from the .env file via docker
# compose env interpolation.
#
# Local-only (DOMAIN=localhost): plain HTTP is served directly on :80 (no
# redirect) because the internal-CA HTTPS cert triggers browser warnings.
# localhost is a secure context in browsers, so Secure cookies still work.
# https://localhost stays available for anyone who trusts the internal CA.

{
	# Operator email for ACME (renewal warnings, key recovery).
	# {$ACME_EMAIL} expands to empty when unset, and Caddy rejects `email` with
	# no argument — crashing the whole container on boot. The `:default` keeps
	# the directive syntactically valid. On localhost Caddy uses its internal CA
	# so ACME email is unused; for a real public deploy set ACME_EMAIL in .env.
	email {$ACME_EMAIL:admin@example.com}

	# Sensible defaults for security headers — applied to all sites below.
	servers {
		protocols h1 h2 h3
	}
}

# Shared app definition — imported by every site block below so the proxy,
# logging, and header posture never drift between HTTP and HTTPS variants.
(app) {
	log {
		output stdout
		format json
	}
	# Record the validated/generated ID returned by Next/Laravel. log_append runs
	# late, after reverse_proxy, so this is the same final ID seen downstream.
	log_append request_id {http.response.header.X-Request-ID}
	encode zstd gzip

	# Hardened headers — same posture as the nginx config inside the frontend
	# container, applied at the edge so they survive any internal hop.
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "SAMEORIGIN"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "interest-cohort=()"
		# CSP in Report-Only mode first. Next.js still needs inline runtime style
		# support; tighten this once nonce/hash coverage is added end to end.
		Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; media-src 'self' blob: https:; connect-src 'self' ws: wss: http: https:; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none';"
		# Caddy already sets Server: header; remove it to reduce fingerprinting.
		-Server
	}

	# The default Laravel/Next stack sets CADDY_UPSTREAM=next:3000. Legacy
	# stacks omit it and keep the historical frontend nginx upstream.
	reverse_proxy {$CADDY_UPSTREAM:frontend:80} {
		header_up Host {host}
		header_up X-Real-IP {remote}
		header_up X-Forwarded-For {remote}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Request-ID {http.request.header.X-Request-ID}
	}

	# Generous request body — bulk imports can be large.
	request_body {
		max_size 256MB
	}
}

# Public domains get auto-HTTPS (Let's Encrypt) + the standard HTTP->HTTPS
# redirect. On DOMAIN=localhost this becomes https://localhost (internal CA).
{$DOMAIN} {
	import app
}

# Local convenience: answer plain HTTP for localhost instead of Caddy's
# default 308 redirect to the untrusted internal-CA HTTPS. Only matches
# Host: localhost on :80 — real public domains are unaffected.
http://localhost {
	import app
}
