{
  "title": "Archive Suite",
  "uid": "archive-suite-v1",
  "schemaVersion": 38,
  "version": 1,
  "panels": [
    {
      "title": "Request Rate",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "expr": "rate(archive_http_request_duration_seconds_count[5m])",
        "legendFormat": "req/s"
      }],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "rate(archive_http_request_duration_seconds_count{status_code=~\"5..\"}[5m])",
        "legendFormat": "errors/s"
      }],
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 0.1, "color": "red"}]}}}
    },
    {
      "title": "Active Requests",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{
        "expr": "archive_active_requests_total",
        "legendFormat": "active"
      }],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "Request Duration p95",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.5, rate(archive_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(archive_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.99, rate(archive_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ]
}
