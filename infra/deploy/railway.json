{
  "$schema": "https://railway.app/railway.schema.json",
  "name": "archive-suite",
  "services": {
    "archive-suite-server": {
      "source": {
        "repo": "${{ RAILWAY_GIT_REPO }}"
      },
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "archive-server/Dockerfile.server"
      },
      "deploy": {
        "healthcheckPath": "/api/health",
        "restartPolicyType": "ON_FAILURE"
      },
      "variables": {
        "NODE_ENV": "production",
        "BACKEND": "postgres",
        "DATABASE_PROVIDER": "postgresql",
        "DATABASE_URL": "${{ Postgres.DATABASE_URL }}",
        "REDIS_URL": "${{ Redis.REDIS_URL }}",
        "JWT_AUTH_SECRET": "${{ secrets.JWT_AUTH_SECRET }}",
        "JWT_SHARE_SECRET": "${{ secrets.JWT_SHARE_SECRET }}",
        "OAUTH_STATE_SECRET": "${{ secrets.OAUTH_STATE_SECRET }}",
        "APP_BASE_URL": "${{ RAILWAY_PUBLIC_DOMAIN }}"
      }
    },
    "archive-suite-frontend": {
      "source": {
        "repo": "${{ RAILWAY_GIT_REPO }}"
      },
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "archive-server/Dockerfile.frontend"
      },
      "deploy": {
        "healthcheckPath": "/",
        "restartPolicyType": "ON_FAILURE"
      },
      "variables": {
        "VITE_BACKEND": "cloud",
        "VITE_API_BASE_URL": "${{ archive-suite-server.RAILWAY_PUBLIC_DOMAIN }}"
      }
    }
  },
  "plugins": {
    "Postgres": {},
    "Redis": {}
  }
}
