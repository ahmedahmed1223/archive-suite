{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "version", "images"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
    "images": {
      "type": "array", "minItems": 7,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "service", "profile", "online", "offlineRef"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "service": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "profile": { "enum": ["core", "media", "edge"] },
          "online": { "type": "string", "pattern": "^[a-z0-9][a-z0-9./_-]*:[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?@sha256:[a-f0-9]{64}$" },
          "offlineRef": { "type": "string", "pattern": "^[a-z0-9][a-z0-9./_-]*:\\$VERSION$" }
        }
      }
    }
  }
}
