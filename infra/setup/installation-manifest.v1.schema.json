{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archive-suite.local/schemas/installation-manifest.v1.schema.json",
  "title": "Archive Suite installation manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "version", "source", "mode", "platform", "runtimeProfiles", "capabilities", "artifacts", "services", "dataPaths", "lastSuccessfulStep", "previousVersion", "operation"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "version": { "type": "string", "minLength": 1 },
    "source": { "enum": ["online", "offline"] },
    "mode": { "enum": ["docker", "native"] },
    "platform": { "type": "string", "minLength": 1 },
    "runtimeProfiles": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "capabilities": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "digest": { "type": "string", "minLength": 1 },
          "checksum": { "type": "string", "minLength": 1 }
        }
      }
    },
    "services": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "dataPaths": { "type": "object", "additionalProperties": { "type": "string", "minLength": 1 } },
    "lastSuccessfulStep": { "type": ["string", "null"] },
    "previousVersion": { "type": ["string", "null"] },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "status", "failedStep", "nextActions"],
      "properties": {
        "type": { "enum": ["install", "repair"] },
        "status": { "enum": ["in-progress", "failed", "succeeded"] },
        "failedStep": { "type": ["string", "null"] },
        "nextActions": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
