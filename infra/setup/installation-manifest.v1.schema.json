{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archive-suite.local/schemas/installation-manifest.v1.schema.json",
  "title": "Archive Suite installation manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "version", "source", "mode", "platform", "runtimeProfiles", "capabilities", "artifacts", "services", "dataPaths", "lastSuccessfulStep", "previousVersion", "operation"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "version": { "type": "string", "minLength": 1 },
    "source": { "enum": ["online", "offline"] },
    "mode": { "enum": ["docker", "native"] },
    "platform": { "type": "string", "minLength": 1 },
    "runtimeProfiles": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "capabilities": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "anyOf": [{ "required": ["digest"] }, { "required": ["checksum"] }],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "digest": { "type": "string", "minLength": 1 },
          "checksum": { "type": "string", "minLength": 1 }
        }
      }
    },
    "services": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "dataPaths": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "pattern": "^(?!.*(?:[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll]|[Aa][Uu][Tt][Hh][Oo][Rr][Ii][Zz][Aa][Tt][Ii][Oo][Nn]|[Cc][Oo][Oo][Kk][Ii][Ee]|[Dd][Ss][Nn]|[Cc][Oo][Nn][Nn][Ee][Cc][Tt][Ii][Oo][Nn]|[Uu][Rr][Ll]|[Kk][Ee][Yy])).+$" },
      "additionalProperties": {
        "type": "string",
        "minLength": 1,
        "allOf": [
          { "not": { "pattern": "^[a-zA-Z][a-zA-Z0-9+.-]*://" } },
          { "not": { "pattern": "(^|[^\\s:/\\\\])[^\\s:/\\\\]+:[^\\s@]+@" } },
          { "not": { "pattern": "(?:[Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]|[Ss][Ee][Cc][Rr][Ee][Tt]|[Tt][Oo][Kk][Ee][Nn]|[Cc][Rr][Ee][Dd][Ee][Nn][Tt][Ii][Aa][Ll])" } }
        ]
      }
    },
    "lastSuccessfulStep": { "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }] },
    "previousVersion": { "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }] },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "status", "failedStep", "nextActions"],
      "properties": {
        "type": { "enum": ["install", "repair"] },
        "status": { "enum": ["in-progress", "failed", "succeeded"] },
        "failedStep": { "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }] },
        "nextActions": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
