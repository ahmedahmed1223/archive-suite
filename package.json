{
  "name": "archive-suite",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@firebase/util",
      "protobufjs"
    ]
  },
  "scripts": {
    "bootstrap": "pnpm install",
    "dev": "pnpm --filter @archive/app run dev",
    "dev:app": "pnpm --filter @archive/app run dev",
    "server": "pnpm --filter archive-server run start",
    "build": "pnpm --filter @archive/app run build",
    "build:app": "pnpm --filter @archive/app run build",
    "build:spa": "pnpm --filter @archive/app run build:spa",
    "build:cloud": "pnpm --filter @archive/app run build:cloud",
    "verify": "pnpm --filter @archive/app run verify && pnpm --filter @archive/core run verify && pnpm --filter archive-server run verify",
    "verify:app": "pnpm --filter @archive/app run verify",
    "verify:core": "pnpm --filter @archive/core run verify",
    "verify:server": "pnpm --filter archive-server run verify",
    "audit:ui": "pnpm --filter @archive/app run audit:ui",
    "audit:ui:headed": "pnpm --filter @archive/app run audit:ui:headed",
    "audit:ui:server": "pnpm --filter @archive/app run audit:ui:server",
    "audit:all": "pnpm run verify && pnpm run audit:ui",
    "security:baseline": "node scripts/verify-security-baseline.mjs",
    "verify:cloud-deploy": "node scripts/verify-cloud-deploy.mjs",
    "docker:config": "docker compose --env-file archive-server/.env.example -f archive-server/docker-compose.yml config",
    "docker:config:postgres": "docker compose --env-file archive-server/.env.example -f archive-server/docker-compose.postgres.yml config",
    "release:verify": "pnpm run verify && pnpm run build:spa && pnpm run build:cloud && pnpm run security:baseline && node scripts/verify-release-readiness.mjs",
    "setup": "node scripts/setup.mjs",
    "deploy": "node scripts/deploy-wizard.mjs",
    "control": "node scripts/control-center.mjs"
  }
}
