{
  "name": "archive-suite",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@firebase/util",
      "protobufjs"
    ]
  },
  "scripts": {
    "bootstrap": "pnpm install",
    "dev": "node scripts/dev-laravel-next.mjs",
    "dev:next": "pnpm --filter @archive/next run dev",
    "dev:laravel": "node scripts/laravel-docker.mjs serve",
    "dev:legacy": "pnpm --filter @archive/app run dev",
    "dev:app": "pnpm run dev:legacy",
    "server": "node scripts/laravel-docker.mjs serve",
    "server:legacy": "pnpm --filter archive-server run start",
    "build": "pnpm run build:next",
    "build:next": "pnpm --filter @archive/next run build",
    "build:legacy": "pnpm --filter @archive/app run build",
    "build:app": "pnpm run build:legacy",
    "build:spa": "pnpm --filter @archive/app run build:spa",
    "build:spa:legacy": "pnpm --filter @archive/app run build:spa",
    "build:cloud": "pnpm --filter @archive/app run build:cloud",
    "build:cloud:legacy": "pnpm --filter @archive/app run build:cloud",
    "verify": "pnpm run verify:laravel-next",
    "verify:laravel-next": "pnpm run verify:cutover && pnpm run verify:api-contracts && pnpm run typecheck && pnpm run build:next && pnpm run verify:laravel",
    "verify:cutover": "node scripts/verify-cutover-defaults.mjs",
    "verify:laravel": "node scripts/laravel-docker.mjs test",
    "verify:laravel-next:live": "node scripts/verify-next-laravel-live.mjs",
    "e2e:next": "pnpm --filter @archive/app exec playwright test tests/next-migration-shell.spec.ts",
    "e2e:next:integration": "pnpm --filter @archive/app exec playwright test tests/next-laravel-integration.spec.ts",
    "verify:legacy": "pnpm --filter @archive/app run verify && pnpm --filter @archive/core run verify && pnpm --filter archive-server run verify",
    "verify:app": "pnpm --filter @archive/app run verify",
    "verify:core": "pnpm --filter @archive/core run verify",
    "verify:server": "pnpm --filter archive-server run verify",
    "typecheck": "pnpm --filter @archive/core run typecheck && pnpm --filter @archive/next run typecheck",
    "typecheck:legacy": "pnpm --filter @archive/app run typecheck && pnpm --filter @archive/core run typecheck && pnpm --filter @archive/next run typecheck && pnpm --filter archive-server run typecheck",
    "typecheck:app": "pnpm --filter @archive/app run typecheck",
    "typecheck:core": "pnpm --filter @archive/core run typecheck",
    "typecheck:next": "pnpm --filter @archive/next run typecheck",
    "typecheck:server": "pnpm --filter archive-server run typecheck",
    "verify:typescript-migration": "pnpm run typecheck && pnpm --filter @archive/app run test",
    "audit:ui": "pnpm --filter @archive/app run audit:ui",
    "audit:ui:headed": "pnpm --filter @archive/app run audit:ui:headed",
    "audit:ui:server": "pnpm --filter @archive/app run audit:ui:server",
    "audit:all": "pnpm run verify && pnpm run audit:ui",
    "security:baseline": "node scripts/verify-security-baseline.mjs",
    "verify:api-contracts": "node scripts/verify-api-contracts.mjs",
    "verify:cloud-deploy": "node scripts/verify-cloud-deploy.mjs",
    "docker:config": "docker compose --env-file archive-server/.env.example -f archive-server/docker-compose.yml config",
    "docker:config:postgres": "docker compose --env-file archive-server/.env.example -f archive-server/docker-compose.postgres.yml config",
    "docker:config:sqlserver": "docker compose --env-file archive-server/.env.example -f archive-server/docker-compose.sqlserver.yml config",
    "release:verify": "pnpm run verify:laravel-next && pnpm run security:baseline && node scripts/verify-release-readiness.mjs",
    "setup": "node scripts/setup.mjs",
    "deploy": "node scripts/deploy-wizard.mjs",
    "control": "node scripts/control-center.mjs"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
