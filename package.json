{
  "name": "archive-suite",
  "version": "1.0.0-rc.1",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@firebase/util",
      "protobufjs"
    ]
  },
  "scripts": {
    "bootstrap": "pnpm install --frozen-lockfile",
    "dev": "node scripts/dev-laravel-next.mjs",
    "dev:next": "pnpm --filter @archive/next run dev",
    "dev:laravel": "node scripts/laravel-docker.mjs serve",
    "server": "node scripts/laravel-docker.mjs serve",
    "build": "pnpm run build:next",
    "build:next": "pnpm --filter @archive/next run build",
    "verify": "pnpm run verify:laravel-next",
    "verify:laravel-next": "pnpm run verify:reproducibility && pnpm run verify:cutover && pnpm run verify:api-contracts && pnpm run typecheck && pnpm run test:next && pnpm run build:next && pnpm run verify:repo-hygiene && pnpm run verify:laravel",
    "verify:reproducibility": "node --test scripts/verify-reproducibility.test.mjs scripts/verify-immutable-images.test.mjs scripts/verify-release-supply-chain.test.mjs scripts/release-license-policy.test.mjs scripts/offline-bundle.test.mjs",
    "verify:cutover": "node scripts/verify-cutover-defaults.mjs",
    "verify:laravel": "node scripts/laravel-docker.mjs test",
    "verify:laravel-next:live": "node scripts/verify-next-laravel-live.mjs",
    "e2e:next": "pnpm --filter @archive/next exec playwright test e2e/next-migration-shell.spec.ts",
    "e2e:next:integration": "pnpm --filter @archive/next exec playwright test e2e/next-laravel-integration.spec.ts",
    "e2e:next:a11y": "pnpm --filter @archive/next exec playwright test e2e/accessibility.spec.ts",
    "typecheck": "pnpm --filter @archive/next run typecheck",
    "typecheck:next": "pnpm --filter @archive/next run typecheck",
    "test:next": "pnpm --filter @archive/next run test",
    "ci": "pnpm run release:verify",
    "ci:docker": "pnpm run docker:config && docker compose --env-file infra/.env.example -f infra/docker-compose.yml build next",
    "security:baseline": "node scripts/verify-security-baseline.mjs",
    "security:audit": "node scripts/verify-dependency-audit.mjs",
    "verify:api-contracts": "node scripts/verify-api-contracts.mjs",
    "verify:infra": "node scripts/verify-infra-config.mjs",
    "verify:repo-hygiene": "node scripts/verify-repo-hygiene.mjs",
    "smoke:watermark": "node scripts/smoke-watermark-ffmpeg.mjs",
    "docker:config": "docker compose --env-file infra/.env.example -f infra/docker-compose.yml config",
    "docker:config:laravel-next": "docker compose --env-file infra/.env.example -f infra/docker-compose.laravel-next.yml config",
    "release:verify": "pnpm run verify:laravel-next && pnpm run security:baseline && pnpm run security:audit && node scripts/verify-release-readiness.mjs",
    "offline:test": "node --test scripts/offline-bundle.test.mjs",
    "offline:bundle": "node scripts/offline-bundle.mjs build",
    "offline:verify": "node scripts/offline-bundle.mjs verify",
    "offline:rehearse": "node scripts/offline-bundle.mjs rehearse",
    "setup": "node scripts/control-center.mjs deploy",
    "deploy": "node scripts/control-center.mjs deploy",
    "control": "node scripts/control-center.mjs"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
